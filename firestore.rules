rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Settings collection - anyone can read, admin can update
    match /settings/{settingsId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Questions collection - anyone can read, admin can write
    match /questions/{questionId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Answers collection - secure with deterministic ID validation
    match /answers/{answerId} {
      allow read: if true;
      allow write: if answerId == request.resource.data.participantId + '_' + request.resource.data.questionId;
    }
    
    // Participants collection - protect leaderboard scores against tampering
    match /participants/{participantId} {
      allow read: if true;
      
      // Prevent public registration from pre-assigning points
      allow create: if request.resource.data.dailyPoints == 0 
                    && request.resource.data.bonusPoints == 0 
                    && request.resource.data.bumperPoints == 0;
                    
      // Allow name changes or admin modifications
      allow update: if true;
      allow delete: if true;
    }
  }
}
